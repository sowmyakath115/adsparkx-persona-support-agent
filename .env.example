# Optional. Without this key, the app still runs using deterministic local generation.
OPENAI_API_KEY=

# Supported: openai, local
AGENT_LLM_PROVIDER=local
AGENT_EMBEDDING_PROVIDER=local

# OpenAI defaults. You can switch to GPT-5/GPT-4o class models based on your account access.
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval and escalation controls
TOP_K=4
MIN_RETRIEVAL_SCORE=0.35
ESCALATE_AFTER_DISSATISFIED_TURNS=2
VECTOR_DB_PATH=storage/chroma
COLLECTION_NAME=cloudops_support_kb
KNOWLEDGE_BASE_DIR=data/knowledge_base
